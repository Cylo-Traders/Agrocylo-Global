// Production Escrow schema
// Tables: users, campaigns, investments, orders, transactions

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  role          String   @default("INVESTOR") // INVESTOR | FARMER | BUYER
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  campaigns   Campaign[]    @relation("FarmerCampaigns")
  investments Investment[]
  orders      Order[]

  @@index([walletAddress])
  @@map("users")
}

model Campaign {
  id             String         @id @default(uuid())
  onChainId      String         @unique // uint64 from contract as string
  farmerAddress  String
  tokenAddress   String
  targetAmount   String         // i128 stored as string
  totalRaised    String         @default("0")
  totalRevenue   String         @default("0")
  trancheReleased String        @default("0")
  imageUrl       String?
  deadline       DateTime
  status         CampaignStatus @default(FUNDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  farmer       User         @relation("FarmerCampaigns", fields: [farmerAddress], references: [walletAddress], onDelete: Restrict)
  investments  Investment[]
  orders       Order[]
  transactions Transaction[]
  disputes     Dispute[]
  products     Product[]

  @@index([farmerAddress])
  @@index([status])
  @@map("campaigns")
}

model Investment {
  id             String   @id @default(uuid())
  campaignId     String
  investorAddress String
  amount         String   // i128 as string
  ledger         Int
  txHash         String?
  createdAt      DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  investor User     @relation(fields: [investorAddress], references: [walletAddress], onDelete: Restrict)

  @@unique([campaignId, investorAddress, ledger])
  @@index([campaignId])
  @@index([investorAddress])
  @@map("investments")
}

model Order {
  id            String      @id @default(uuid())
  onChainId     String      @unique // uint64 as string
  campaignId    String
  buyerAddress  String
  amount        String      // i128 as string
  status        OrderStatus @default(PENDING)
  ledger        Int
  txHash        String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  buyer    User     @relation(fields: [buyerAddress], references: [walletAddress], onDelete: Restrict)
  disputes Dispute[]

  @@index([campaignId])
  @@index([buyerAddress])
  @@map("orders")
}

model Transaction {
  id            String            @id @default(uuid())
  campaignId    String?
  walletAddress String?
  eventType     String
  status        TransactionStatus @default(submitted)
  payload       Json
  ledger        Int
  eventIndex    Int
  txHash        String?
  processedAt   DateTime          @default(now())

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@unique([ledger, eventIndex])
  @@index([campaignId])
  @@index([eventType])
  @@index([walletAddress])
  @@index([txHash])
  @@map("transactions")
}

model AuthNonce {
  id            String   @id @default(uuid())
  walletAddress String
  nonce         String   @unique
  audience      String   @default("agro-production")
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime @default(now())

  @@index([nonce])
  @@index([walletAddress])
  @@map("auth_nonces")
}

model EventCursor {
  id         String   @id @default(uuid())
  contractId String
  ledger     Int
  eventIndex Int
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@unique([contractId])
  @@map("event_cursors")
}

enum CampaignStatus {
  FUNDING
  FUNDED
  IN_PRODUCTION
  HARVESTED
  SETTLED
  FAILED
  DISPUTED
}

enum TransactionStatus {
  awaiting_signature
  submitted
  confirmed
  indexed
  failed
}

enum OrderStatus {
  PENDING
  CONFIRMED
}

enum DisputeStatus {
  Open
  EvidenceSubmitted
  Resolved
  Dismissed
}

model Dispute {
  id                  String           @id @default(uuid())
  campaignId          String
  orderId             String?
  initiatorAddress    String
  respondentAddress   String
  status              DisputeStatus    @default(Open)
  resolutionOutcome   String?
  resolutionNotes     String?
  transactionHash     String           @unique
  ledgerSequence      Int
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  campaign            Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  order               Order?           @relation(fields: [orderId], references: [id], onDelete: SetNull)
  evidence            DisputeEvidence[]
  auditEntries        DisputeAuditEntry[]

  @@index([campaignId])
  @@index([orderId])
  @@index([initiatorAddress])
  @@index([respondentAddress])
  @@index([status])
  @@index([transactionHash])
  @@map("disputes")
}

model DisputeEvidence {
  id              String   @id @default(uuid())
  disputeId       String
  submitterAddress String
  evidenceUrl     String
  evidenceHash    String
  submittedAt     DateTime @default(now())

  dispute         Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([submitterAddress])
  @@map("dispute_evidence")
}

model DisputeAuditEntry {
  id            String   @id @default(uuid())
  disputeId     String
  action        String   // "opened", "evidence_submitted", "resolved", "dismissed"
  actorAddress  String
  details       Json     @default("{}")
  createdAt     DateTime @default(now())

  dispute       Dispute  @relation(fields: [disputeId], references: [id], onDelete: Cascade)

  @@index([disputeId])
  @@index([createdAt])
  @@map("dispute_audit_entries")
}
