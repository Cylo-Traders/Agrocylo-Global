# Agro Production local development environment
# Copy this file to .env.local for the Next.js client and/or .env for the server.
# Values are safe examples/placeholders; replace REPLACE_WITH_* before using a live deployment.

# -----------------------------------------------------------------------------
# Server runtime variables (agro-production/server)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=5001
LOG_LEVEL=debug

# PostgreSQL connection used by Prisma and the API server.
DATABASE_URL=postgresql://localhost:5432/agrocylo_production

# Soroban RPC endpoint used by server-side watchers and contract calls.
RPC_URL=https://soroban-testnet.stellar.org

# Server-side contract IDs. Keep the canonical server names without NEXT_PUBLIC_.
PRODUCTION_CONTRACT_ID=REPLACE_WITH_PRODUCTION_CONTRACT_ID
ESCROW_CONTRACT_ID=REPLACE_WITH_ESCROW_CONTRACT_ID
PRODUCTION_ESCROW_CONTRACT_ID=REPLACE_WITH_PRODUCTION_ESCROW_CONTRACT_ID

# Optional rate limiting and operational settings.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WRITE_MAX_REQUESTS=10
REDIS_URL=redis://localhost:6379
CORS_ORIGINS=http://localhost:3000
METRICS_API_KEY=REDACTED_EXAMPLE_VALUE
SHUTDOWN_TIMEOUT_MS=15000

# Optional Supabase storage for campaign images.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=REDACTED_EXAMPLE_VALUE
SUPABASE_SERVICE_ROLE_KEY=REDACTED_EXAMPLE_VALUE
SUPABASE_CAMPAIGN_IMAGES_BUCKET=campaign-images
CAMPAIGN_IMAGE_PLACEHOLDER_URL=https://placehold.co/800x800/png?text=No+Image

# -----------------------------------------------------------------------------
# Client public variables (agro-production/client)
# -----------------------------------------------------------------------------
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to browser code.
NEXT_PUBLIC_API_URL=http://localhost:5001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:5001/ws
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_PRODUCTION_CONTRACT_ID=REPLACE_WITH_PRODUCTION_CONTRACT_ID
NEXT_PUBLIC_ANALYTICS_ENABLED=false
NEXT_PUBLIC_ERROR_REPORTING_ENABLED=false
