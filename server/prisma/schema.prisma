// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Notification {
  id            String   @id @default(uuid())
  walletAddress String
  message       String
  orderId       String?
  type          String
  isRead        Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([walletAddress]) 
}

model User {
  id            String   @id @default(uuid())
  walletAddress String   @unique
  role          String?  // e.g., "BUYER", "SELLER"
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  ordersAsBuyer Order[]  @relation("BuyerOrders")
  ordersAsSeller Order[] @relation("SellerOrders")

  @@map("users")
}

model BuyerDemand {
  id              String    @id @default(uuid())
  buyerWallet     String    @map("buyer_wallet")
  cropName        String    @map("crop_name")
  quantityWanted  String?   @map("quantity_wanted")
  unit            String?
  maxPricePerUnit String?   @map("max_price_per_unit")
  currency        String?
  region          String?
  notes           String?
  neededBy        DateTime? @map("needed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@index([buyerWallet])
  @@map("buyer_demands")
}

model FarmerSupply {
  id                 String    @id @default(uuid())
  farmerWallet       String    @map("farmer_wallet")
  cropName           String    @map("crop_name")
  quantityAvailable  String    @map("quantity_available")
  unit               String?
  pricePerUnit       String?   @map("price_per_unit")
  currency           String?
  availableFrom      DateTime? @map("available_from")
  availableUntil     DateTime? @map("available_until")
  notes              String?
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([farmerWallet])
  @@map("farmer_supplies")
}

model Product {
  id            String   @id @default(uuid())
  farmerWallet  String   
  name          String
  pricePerUnit  String   
  currency      String   
  isAvailable   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]

  @@map("products")
}

model Order {
  id            String   @id @default(uuid())
  orderIdOnChain String  @unique 
  buyerAddress  String
  sellerAddress String
  amount        String
  token         String
  status        String   
  productId     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  buyerUser     User     @relation("BuyerOrders", fields: [buyerAddress], references: [walletAddress], onDelete: Cascade)
  sellerUser    User     @relation("SellerOrders", fields: [sellerAddress], references: [walletAddress], onDelete: Cascade)
  product       Product? @relation(fields: [productId], references: [id])

  @@map("orders")
}
